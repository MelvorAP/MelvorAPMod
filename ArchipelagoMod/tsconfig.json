{
  "compilerOptions": {
    "target": "es2016",
    "lib": [
      "es2019",
      "DOM"
    ],
    "allowUmdGlobalAccess": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "./build",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/**/*",
    "./node_modules/melvor-types",
  ]
}
